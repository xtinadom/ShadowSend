# Public site URL (Stripe success/cancel when Origin is missing; SEO metadata base)
# Production: https://shadow-send.com
# Local: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe — get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Stripe Price IDs (Products → Prices in Dashboard), one per service tier
NEXT_PUBLIC_STRIPE_PRICE_STANDARD=price_...
NEXT_PUBLIC_STRIPE_PRICE_PAPER_ONLY=price_...
NEXT_PUBLIC_STRIPE_PRICE_TRACKED=price_...

# Optional: for Stripe CLI / production webhooks
STRIPE_WEBHOOK_SECRET=whsec_...
