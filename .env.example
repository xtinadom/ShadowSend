# Optional: lock the whole site behind HTTP Basic Auth (browser popup). Leave unset for a public site.
# Stripe webhooks, /email/* images, and Next static assets stay reachable without the password.
# On Vercel: add for Production (and Preview if you use preview URLs), then redeploy. Name must match exactly.
# SITE_ACCESS_PASSWORD=your-secret
# SITE_ACCESS_USER=   # optional; if set, username must match (password still required)

# Public site URL (Stripe success/cancel when Origin is missing; SEO metadata base)
# Production: https://shadow-send.com
# Local: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe — get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Stripe Price IDs — on Vercel use STRIPE_PRICE_* (recommended; always runtime).
# NEXT_PUBLIC_STRIPE_PRICE_* also works but can misbehave if build cache is stale; redeploy without cache if demo checkout persists.
STRIPE_PRICE_STANDARD=price_...
STRIPE_PRICE_PAPER_ONLY=price_...
STRIPE_PRICE_TRACKED=price_...

# Optional: $0.50 test product — Stripe Price ID must match amount in Dashboard (50¢).
# STRIPE_PRICE_TEST_ZERO=price_...

# Optional: for Stripe CLI / production webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend — order confirmation emails (https://resend.com). Verify your domain for production.
# RESEND_API_KEY=re_...
# RESEND_FROM=ShadowSend <orders@yourdomain.com>

SITE_ACCESS_PASSWORD=notliveyet!
# optional:
# SITE_ACCESS_USER=admin
